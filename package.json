{
	"name": "yourstar",
	"version": "0.1.0",
	"description": "Your * — personal context layer for AI, available anywhere your cursor is",
	"main": "dist-electron/main.js",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && electron-builder",
		"build:vite": "tsc && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"better-sqlite3": "^12.8.0",
		"electron": "^41.1.0",
		"framer-motion": "^12.38.0",
		"keytar": "^7.9.0",
		"openai": "^6.33.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"electron-builder": "^26.8.1",
		"jsdom": "^29.0.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.3",
		"vite-plugin-electron": "^0.29.1",
		"vite-plugin-electron-renderer": "^0.14.6",
		"vitest": "^4.1.2"
	},
	"build": {
		"appId": "com.yourstar.app",
		"productName": "Your Star",
		"mac": {
			"category": "public.app-category.productivity",
			"target": "dmg"
		},
		"directories": {
			"output": "release"
		},
		"files": [
			"dist/**/*",
			"dist-electron/**/*"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"electron",
			"better-sqlite3",
			"keytar"
		]
	}
}
